## Server environment
# Copy to server/.env and adjust. Do not commit server/.env (see root .gitignore).

# MongoDB (recommended for persistence). If unset, server uses server/.data/matches.json.
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=pitchpulse

# Optional: HTTP port (default 3001)
# PORT=3001

# Production: set to your frontend origin for CORS (dev often uses reflect-any-origin).
# CLIENT_ORIGIN=https://your-app.example.com
